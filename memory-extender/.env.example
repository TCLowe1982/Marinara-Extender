# Marinara Extender — configuration template.
#
# EVERYTHING HERE IS OPTIONAL. With a local Ollama running the default model,
# the sidecar works with no .env at all. Copy this file to `.env` only if you
# want to change a default or add an external API fallback:
#     cp .env.example .env      (PowerShell: Copy-Item .env.example .env)
# Values set here override the built-in defaults. Lines starting with # are
# ignored, so an unedited copy changes nothing.

# ── Local inference (primary path) ────────────────────────────────────────────
# OpenAI-compatible local endpoint — works with ANY OpenAI-compatible server,
# NOT just Ollama. The default is Ollama; to use a different backend, point this
# at its OpenAI endpoint and set the model below. Examples:
#     Ollama      http://127.0.0.1:11434/v1   (default)
#     KoboldCpp   http://127.0.0.1:5001/v1
#     LM Studio   http://127.0.0.1:1234/v1
#     llama.cpp   http://127.0.0.1:8080/v1
# (The launcher's auto-start/model-pull is Ollama-specific; with another backend,
# start it yourself, set the two lines below, and run the sidecar — it just talks
# /chat/completions.) Set EMPTY to disable local and use the external API only.
# MARINARA_EXTENDER_LOCAL_URL=http://127.0.0.1:11434/v1
# Local model — the id YOUR server exposes (check its /v1/models). Use an
# UNCENSORED model: an alignment-tuned one refuses to analyze adult roleplay
# content, which breaks the pipeline.
# MARINARA_EXTENDER_LOCAL_MODEL=dolphin3:8b
# Embedding model — semantic chunk merging + the through-line arc kNN generator.
# Hits the SAME LOCAL_URL via /v1/embeddings, so it works on any backend that
# serves embeddings (Ollama does; some KoboldCpp builds don't). DEFAULT ON:
# nomic-embed-text (Ollama: one-time `ollama pull nomic-embed-text`). Set to 0
# (or "off") to disable embeddings entirely; name another model to swap.
# MARINARA_EXTENDER_EMBED_MODEL=nomic-embed-text

# ── External API (optional fallback — used only if local is unavailable) ───────
# Your OpenAI-compatible API key. Leave empty to run local-only.
MARINARA_EXTENDER_API_KEY=
# MARINARA_EXTENDER_DIGEST_UPSTREAM=https://api.openai.com
# MARINARA_EXTENDER_DIGEST_MODEL=gpt-4o-mini

# ── Server & behavior ──────────────────────────────────────────────────────────
# MARINARA_EXTENDER_PORT=3001
# MARINARA_EXTENDER_DATA=./data
# Extra CORS origin, if you run Marinara on a non-loopback URL.
# MARINARA_EXTENDER_ALLOWED_ORIGIN=
# Conversational time-sense (off for v1.0).
# MARINARA_EXTENDER_TIMESENSE=0
# Console progress bar during imports (on by default).
# MARINARA_EXTENDER_PROGRESS=1
# Per-scope token budgets for the memory loaded each turn (re-read live, no
# restart needed). Keep the total under the engine lorebook injection budget
# (the extender sets that to 16384) or the engine silently drops the memory
# entry. Defaults total ~7k, well under the ceiling. The launcher's [L] View
# log shows effective usage per turn (e.g. "char:45/2000 tokens").
# MARINARA_EXTENDER_BUDGET_CHAT=4000
# MARINARA_EXTENDER_BUDGET_CHARACTER=2000
# MARINARA_EXTENDER_BUDGET_GLOBAL=1000
# Inject every entry regardless of budget (testing only).
# MARINARA_EXTENDER_EIDETIC=0
